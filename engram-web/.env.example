# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# Miner backend URL
MINER_API_URL=http://localhost:8091

# xAI Grok API key (for /memory AI chat — get one at console.x.ai)
XAI_API_KEY=

# Arweave wallet JWK — generate locally, never share or request over HTTP:
#   node -e "require('arweave').init({}).wallets.generate().then(k => console.log(JSON.stringify(k)))"
# Fund the returned address with AR before enabling uploads.
ARWEAVE_ENV=mainnet
ARWEAVE_KEY=

# Admin bearer token for sensitive routes (e.g. GET /api/arweave/wallet).
# Fail-closed: if unset, those routes reject ALL requests with 401.
# Generate a strong token: openssl rand -hex 32
ENGRAM_ADMIN_TOKEN=

# Gateway signing keypair for outgoing miner requests.
# When set, all ingest/query calls are sr25519-signed so miners running with
# REQUIRE_HOTKEY_SIG=true will accept them. When unset, requests are unsigned
# (miners must have REQUIRE_HOTKEY_SIG=false — fine for testnet/dev).
# Use a dedicated hotkey registered on subnet 450, not your cold-key mnemonic.
# Generate: btcli wallet new_hotkey --wallet.name engram --wallet.hotkey gateway
# Then export: btcli wallet export --wallet.name engram --wallet.hotkey gateway
GATEWAY_MNEMONIC=
